SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key

# 可選：本機覆寫機密（Git 勿提交），載入順序為 .env → .env.local（後者覆寫）
# 檔名為 .env.local（與 server.js 同資料夾）

# 建議後端使用（Project Settings → API → service_role，勿提交或用於前端）：
SUPABASE_SERVICE_ROLE_KEY=

# 本機除錯：讓網頁 alert / Console 顯示 Postgres 詳細錯誤（請勿對外公開環境長開）
SHOW_VOTE_ERROR_DETAILS=1
